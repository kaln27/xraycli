#!/usr/bin/env bash
#
# xraycli — user-scope control script for an Xray-core proxy.
#
# Everything it manages lives under $HOME (XDG dirs) and a *user* systemd unit.
# It never uses sudo and never writes outside the invoking user's scope.
#
#   Layout
#     ~/.local/bin/xraycli                    this script
#     ~/.local/share/xraycli/core/xray        the Xray-core binary + geodata
#     ~/.config/xraycli/config.json           generated Xray config
#     ~/.config/xraycli/xraycli.env           ports / listen / version
#     ~/.config/xraycli/nodes.json            saved server nodes
#     ~/.config/xraycli/active_outbound.json  outbound used by the active node
#     ~/.local/state/xraycli/{access,error}.log
#     ~/.config/systemd/user/xraycli.service  user systemd unit
#
# Run `xraycli help` for the command list.
#
set -uo pipefail

readonly XRAYCLI_VERSION_SELF="0.1.0"
readonly APP="xraycli"

# --------------------------------------------------------------------------- #
#  Paths (XDG, all under $HOME)                                               #
# --------------------------------------------------------------------------- #
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_STATE_HOME:=$HOME/.local/state}"

readonly BIN_SELF="$HOME/.local/bin/xraycli"
readonly DATA_DIR="$XDG_DATA_HOME/$APP"
readonly CORE_DIR="$DATA_DIR/core"
# Which proxy core runs the tunnel. Resolved from XRAYCLI_CORE in load_env;
# CORE_BIN is derived from it. Both cores may coexist in CORE_DIR.
CORE="xray"
CORE_BIN="$CORE_DIR/xray"
readonly CONFIG_DIR="$XDG_CONFIG_HOME/$APP"
readonly STATE_DIR="$XDG_STATE_HOME/$APP"
readonly SERVICE_NAME="$APP.service"
# SYSTEMD_DIR/SERVICE_FILE are resolved at runtime by init_systemd_paths(): the
# --user manager may run with a different HOME than this shell (e.g. root with a
# custom $HOME), so we must target the directory the manager actually scans.
SYSTEMD_DIR="$XDG_CONFIG_HOME/systemd/user"
SERVICE_FILE="$SYSTEMD_DIR/$SERVICE_NAME"

readonly ENV_FILE="$CONFIG_DIR/xraycli.env"
readonly CONFIG_FILE="$CONFIG_DIR/config.json"
readonly NODES_FILE="$CONFIG_DIR/nodes.json"
readonly ACTIVE_OUTBOUND="$CONFIG_DIR/active_outbound.json"   # legacy (xray outbound)
readonly ACTIVE_DESC="$CONFIG_DIR/active_descriptor.json"     # active node descriptor
readonly ACTIVE_NAME_FILE="$CONFIG_DIR/active_name"
readonly SUB_FILE="$CONFIG_DIR/subscription"
readonly PID_FILE="$STATE_DIR/xray.pid"
readonly SUPERVISOR_PID="$STATE_DIR/supervisor.pid"
readonly BASHRC="$HOME/.bashrc"
readonly CRON_TAG="# xraycli-autostart"

# Filled in by init_service_mode(): "systemd" or "self".
SERVICE_MODE="self"

# --------------------------------------------------------------------------- #
#  Output helpers                                                             #
# --------------------------------------------------------------------------- #
if [ -t 1 ]; then
  c_red=$'\033[31m'; c_grn=$'\033[32m'; c_ylw=$'\033[33m'
  c_blu=$'\033[34m'; c_dim=$'\033[2m'; c_bld=$'\033[1m'; c_rst=$'\033[0m'
else
  c_red=; c_grn=; c_ylw=; c_blu=; c_dim=; c_bld=; c_rst=
fi
info() { printf '%s==>%s %s\n' "$c_blu" "$c_rst" "$*"; }
ok()   { printf '%s ✓ %s %s\n' "$c_grn" "$c_rst" "$*"; }
warn() { printf '%s ! %s %s\n' "$c_ylw" "$c_rst" "$*" >&2; }
die()  { printf '%s ✗ %s %s\n' "$c_red" "$c_rst" "$*" >&2; exit 1; }

have() { command -v "$1" >/dev/null 2>&1; }
need_jq() { have jq || die "jq is required for node management — install it (e.g. apt install jq)"; }

# --------------------------------------------------------------------------- #
#  Environment                                                                #
# --------------------------------------------------------------------------- #
load_env() {
  LISTEN="127.0.0.1"; SOCKS_PORT="10808"; HTTP_PORT="10809"; XRAYCLI_VERSION="unknown"
  XRAYCLI_CORE="xray"
  # shellcheck disable=SC1090
  [ -f "$ENV_FILE" ] && . "$ENV_FILE"
  LISTEN="${XRAYCLI_LISTEN:-$LISTEN}"
  SOCKS_PORT="${XRAYCLI_SOCKS_PORT:-$SOCKS_PORT}"
  HTTP_PORT="${XRAYCLI_HTTP_PORT:-$HTTP_PORT}"
  XRAYCLI_VERSION="${XRAYCLI_VERSION:-unknown}"
  case "${XRAYCLI_CORE:-xray}" in sing-box|singbox) CORE="sing-box" ;; *) CORE="xray" ;; esac
  CORE_BIN="$CORE_DIR/$CORE"
}

# --------------------------------------------------------------------------- #
#  Core abstraction — everything core-specific funnels through these           #
# --------------------------------------------------------------------------- #
core_check() { # validate <cfg>; 0 = ok
  local f="${1:-$CONFIG_FILE}"
  if [ "$CORE" = sing-box ]; then "$CORE_BIN" check -c "$f" >/dev/null 2>&1
  else XRAY_LOCATION_ASSET="$CORE_DIR" "$CORE_BIN" -test -config "$f" >/dev/null 2>&1; fi
}
core_run_cmd() {  # print the run command for the systemd ExecStart line
  if [ "$CORE" = sing-box ]; then printf '%s run -c %s' "$CORE_BIN" "$CONFIG_FILE"
  else printf '%s run -config %s' "$CORE_BIN" "$CONFIG_FILE"; fi
}

# Which node types the ACTIVE core can actually run. hasObfs=1 means the node
# carries (salamander) obfs. Xray can't do obfs'd hysteria2; sing-box can.
core_supports() {  # <type> <hasObfs>
  local t="$1" obfs="${2:-0}"
  case "$t" in
    vless|vmess|trojan|shadowsocks) return 0 ;;
    hysteria2)
      [ "$CORE" = sing-box ] && return 0
      [ "$obfs" = 1 ] && return 1   # xray: no Salamander obfs
      return 0 ;;
    *) return 1 ;;
  esac
}

ensure_installed() {
  [ -x "$CORE_BIN" ] || die "$CORE core not found at $CORE_BIN — run install.sh (or: xraycli core <name>)"
}

core_version() {
  [ -x "$CORE_BIN" ] || { echo "n/a"; return; }
  if [ "$CORE" = sing-box ]; then
    "$CORE_BIN" version 2>/dev/null | head -1 | awk '{print $3}'
  else
    XRAY_LOCATION_ASSET="$CORE_DIR" "$CORE_BIN" version 2>/dev/null | head -1 | awk '{print $2}'
  fi
}

# --------------------------------------------------------------------------- #
#  systemd / process helpers                                                  #
# --------------------------------------------------------------------------- #
have_systemd_user() { have systemctl && systemctl --user show-environment >/dev/null 2>&1; }
service_installed() { [ -f "$SERVICE_FILE" ]; }
use_systemd() { [ "$SERVICE_MODE" = systemd ]; }

# The --user manager searches units relative to ITS OWN environment. When this
# shell's $HOME differs from the manager's (e.g. root logged in with a custom
# HOME), $HOME/.config/systemd/user is NOT scanned. Resolve the real directory
# from the manager's exported HOME/XDG_CONFIG_HOME so units land where it looks.
init_systemd_paths() {
  local env xdg home
  if have systemctl; then
    env="$(systemctl --user show-environment 2>/dev/null)" || env=""
    xdg="$(printf '%s\n' "$env" | sed -n 's/^XDG_CONFIG_HOME=//p' | head -1)"
    home="$(printf '%s\n' "$env" | sed -n 's/^HOME=//p' | head -1)"
  fi
  if   [ -n "${xdg:-}" ];  then SYSTEMD_DIR="$xdg/systemd/user"
  elif [ -n "${home:-}" ]; then SYSTEMD_DIR="$home/.config/systemd/user"
  else                          SYSTEMD_DIR="$XDG_CONFIG_HOME/systemd/user"; fi
  SERVICE_FILE="$SYSTEMD_DIR/$SERVICE_NAME"
}

# Decide how to run the service. Use systemd ONLY when its user-unit directory
# lives under this $HOME (so nothing lands outside the user's home, e.g. /root).
# Otherwise, and when XRAYCLI_NO_SYSTEMD=1, run a self-managed supervisor — the
# whole service then stays under $HOME with no external footprint.
init_service_mode() {
  SERVICE_MODE="self"
  [ "${XRAYCLI_NO_SYSTEMD:-0}" = 1 ] && return
  if have_systemd_user; then
    case "$SYSTEMD_DIR/" in "$HOME"/*) SERVICE_MODE="systemd" ;; esac
  fi
}

is_running() {
  if use_systemd; then
    systemctl --user is-active --quiet "$SERVICE_NAME"
  else
    sm_running
  fi
}

write_service_unit() {
  mkdir -p "$SYSTEMD_DIR"
  # Absolute paths (NOT %h): xraycli's files live under this shell's $HOME, which
  # may differ from the manager's home that %h would expand to.
  local env_line=""
  [ "$CORE" = xray ] && env_line="Environment=XRAY_LOCATION_ASSET=$CORE_DIR"
  cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=$CORE proxy (managed by xraycli)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
$env_line
ExecStart=$(core_run_cmd)
Restart=on-failure
RestartSec=5
NoNewPrivileges=true

[Install]
WantedBy=default.target
EOF
  have_systemd_user && systemctl --user daemon-reload 2>/dev/null || true
}

# ---- self-managed supervisor (no systemd; everything under $HOME) -------- #
sm_running() { [ -f "$SUPERVISOR_PID" ] && kill -0 "$(cat "$SUPERVISOR_PID" 2>/dev/null)" 2>/dev/null; }

# Internal: runs xray in a loop, restarting it on crash until signalled to stop.
cmd_supervise() {
  load_env
  mkdir -p "$STATE_DIR"
  echo "$$" > "$SUPERVISOR_PID"
  local xpid=""
  _sv_term() { [ -n "$xpid" ] && kill "$xpid" 2>/dev/null; rm -f "$PID_FILE" "$SUPERVISOR_PID"; exit 0; }
  trap _sv_term TERM INT
  while :; do
    if [ "$CORE" = sing-box ]; then
      "$CORE_BIN" run -c "$CONFIG_FILE" >>"$STATE_DIR/error.log" 2>&1 &
    else
      XRAY_LOCATION_ASSET="$CORE_DIR" "$CORE_BIN" run -config "$CONFIG_FILE" >>"$STATE_DIR/error.log" 2>&1 &
    fi
    xpid=$!; echo "$xpid" > "$PID_FILE"
    wait "$xpid"           # returns when the core exits, or is interrupted by a trap
    sleep 2                # throttle restarts on a crash loop
  done
}

sm_start() {
  is_running && { warn "already running (pid $(cat "$PID_FILE" 2>/dev/null))"; return 0; }
  ensure_installed
  mkdir -p "$STATE_DIR"; rm -f "$SUPERVISOR_PID"
  setsid "$BIN_SELF" __supervise >>"$STATE_DIR/error.log" 2>&1 < /dev/null &
  local i
  for (( i=0; i<10; i++ )); do sm_running && break; sleep 0.3; done
  sleep 0.4
  if is_running; then ok "started (self-managed, supervisor pid $(cat "$SUPERVISOR_PID" 2>/dev/null))"
  else die "failed to start — check $STATE_DIR/error.log"; fi
}

sm_stop() {
  local spid i
  if sm_running; then
    spid="$(cat "$SUPERVISOR_PID")"
    kill "$spid" 2>/dev/null
    for (( i=0; i<24; i++ )); do kill -0 "$spid" 2>/dev/null || break; sleep 0.25; done
    kill -0 "$spid" 2>/dev/null && kill -9 "$spid" 2>/dev/null
    ok "stopped"
  else
    warn "not running"
  fi
  [ -f "$PID_FILE" ] && kill "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null
  rm -f "$PID_FILE" "$SUPERVISOR_PID"
}

# ---- boot autostart for self-managed mode (crontab @reboot) -------------- #
# cron runs jobs with HOME from /etc/passwd, so we pin HOME to this install's.
cron_enable() {
  have crontab || { warn "cron not found — no boot autostart; run 'xraycli start' after boot"; return 1; }
  local line="@reboot HOME=$HOME $BIN_SELF start >/dev/null 2>&1 $CRON_TAG"
  { crontab -l 2>/dev/null | grep -vF "$CRON_TAG"; printf '%s\n' "$line"; } | crontab - 2>/dev/null \
    && ok "boot autostart enabled (crontab @reboot)" \
    || warn "could not update crontab"
}
cron_disable() {
  have crontab || return 0
  local cur; cur="$(crontab -l 2>/dev/null | grep -vF "$CRON_TAG")"
  printf '%s\n' "$cur" | grep -q . && printf '%s\n' "$cur" | crontab - 2>/dev/null || crontab -r 2>/dev/null || true
}

restart_if_running() { if is_running; then cmd_restart; fi; }

# --------------------------------------------------------------------------- #
#  Config generation (single source of truth, used by install.sh too)        #
# --------------------------------------------------------------------------- #
cmd_regen() {
  load_env
  mkdir -p "$CONFIG_DIR" "$STATE_DIR"
  # Resolve the active node's proxy outbound for the CURRENT core.
  local proxy_ob=""
  if [ -f "$ACTIVE_DESC" ]; then
    proxy_ob="$(build_proxy_outbound "$(cat "$ACTIVE_DESC")" 2>/dev/null || true)"
  elif [ "$CORE" = xray ] && [ -f "$ACTIVE_OUTBOUND" ]; then
    proxy_ob="$(cat "$ACTIVE_OUTBOUND")"   # legacy pre-descriptor node (xray only)
  fi
  if [ "$CORE" = sing-box ]; then regen_singbox "$proxy_ob"; else regen_xray "$proxy_ob"; fi
  if [ -x "$CORE_BIN" ]; then
    core_check "$CONFIG_FILE" \
      || warn "generated config did not pass '$CORE' validation (active node may be malformed)"
  fi
}

regen_xray() {  # <proxy-outbound-json|"">
  local proxy_ob="${1:-}"
  [ -n "$proxy_ob" ] || proxy_ob='{ "tag": "proxy", "protocol": "freedom", "settings": {} }'
  cat > "$CONFIG_FILE" <<EOF
{
  "log": {
    "loglevel": "warning",
    "access": "$STATE_DIR/access.log",
    "error": "$STATE_DIR/error.log"
  },
  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "$LISTEN",
      "port": $SOCKS_PORT,
      "protocol": "socks",
      "settings": { "udp": true, "auth": "noauth" },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls", "quic"] }
    },
    {
      "tag": "http-in",
      "listen": "$LISTEN",
      "port": $HTTP_PORT,
      "protocol": "http",
      "sniffing": { "enabled": true, "destOverride": ["http", "tls"] }
    }
  ],
  "outbounds": [
    $proxy_ob,
    { "tag": "direct", "protocol": "freedom", "settings": {} },
    { "tag": "block", "protocol": "blackhole", "settings": {} }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      { "type": "field", "ip": ["geoip:private"], "outboundTag": "direct" }
    ]
  }
}
EOF
}

regen_singbox() {  # <proxy-outbound-json|"">
  local proxy_ob="${1:-}"
  [ -n "$proxy_ob" ] || proxy_ob='{ "type": "direct", "tag": "proxy" }'
  cat > "$CONFIG_FILE" <<EOF
{
  "log": { "level": "warn", "output": "$STATE_DIR/error.log", "timestamp": true },
  "inbounds": [
    { "type": "socks", "tag": "socks-in", "listen": "$LISTEN", "listen_port": $SOCKS_PORT },
    { "type": "http",  "tag": "http-in",  "listen": "$LISTEN", "listen_port": $HTTP_PORT }
  ],
  "outbounds": [
    $proxy_ob,
    { "type": "direct", "tag": "direct" }
  ],
  "route": {
    "rules": [ { "ip_is_private": true, "outbound": "direct" } ],
    "final": "proxy"
  }
}
EOF
}

# --------------------------------------------------------------------------- #
#  Node selection helpers                                                     #
# --------------------------------------------------------------------------- #
ensure_nodes() { mkdir -p "$CONFIG_DIR"; [ -f "$NODES_FILE" ] || echo '[]' > "$NODES_FILE"; }

current_name() { [ -f "$ACTIVE_NAME_FILE" ] && cat "$ACTIVE_NAME_FILE" || echo ""; }

select_node() {  # echoes the JSON node for <index|name>, or fails
  local sel="$1"
  if [[ "$sel" =~ ^[0-9]+$ ]]; then
    jq -e ".[$sel]" "$NODES_FILE" 2>/dev/null
  else
    jq -e --arg n "$sel" 'map(select(.name==$n)) | .[0] // empty' "$NODES_FILE" 2>/dev/null
  fi
}

# --------------------------------------------------------------------------- #
#  Commands: lifecycle                                                        #
# --------------------------------------------------------------------------- #
cmd_start() {
  ensure_installed
  [ -f "$CONFIG_FILE" ] || cmd_regen
  if use_systemd; then
    systemctl --user daemon-reload 2>/dev/null || true
    if systemctl --user start "$SERVICE_NAME" 2>/dev/null; then
      ok "started (systemd user service)"
    else
      warn "systemd could not start the unit — using the self-managed supervisor instead"
      sm_start
    fi
  else
    sm_start
  fi
}

cmd_stop() {
  if use_systemd; then
    systemctl --user stop "$SERVICE_NAME" && ok "stopped"
  else
    sm_stop
  fi
}

cmd_restart() {
  ensure_installed
  if use_systemd; then
    systemctl --user daemon-reload 2>/dev/null || true
    if systemctl --user restart "$SERVICE_NAME" 2>/dev/null; then ok "restarted"
    else warn "systemd restart failed — using the self-managed supervisor"; sm_stop; sm_start; fi
  else
    sm_stop; sm_start
  fi
}

cmd_enable() {
  ensure_installed
  [ -f "$CONFIG_FILE" ] || cmd_regen
  if use_systemd; then
    write_service_unit
    if have loginctl; then
      loginctl enable-linger "$(id -un)" 2>/dev/null \
        && ok "enabled linger (service runs even when logged out)" \
        || warn "could not enable linger (service may stop on logout)"
    fi
    systemctl --user daemon-reload 2>/dev/null || true
    if systemctl --user enable --now "$SERVICE_NAME" 2>/dev/null; then
      ok "enabled + started on login"; return
    fi
    warn "systemd enable failed — falling back to the self-managed supervisor"
  fi
  # self-managed: boot autostart via crontab @reboot, then start now
  cron_enable
  sm_start
}

cmd_disable() {
  if use_systemd; then
    systemctl --user disable --now "$SERVICE_NAME" 2>/dev/null && ok "disabled + stopped"
    warn "note: user 'linger' is left enabled (user-global). Disable with: loginctl disable-linger $(id -un)"
  else
    cron_disable && ok "boot autostart removed"
    sm_stop
  fi
}

cmd_status() {
  load_env
  local running node mode
  node="$(current_name)"; [ -n "$node" ] || node="(direct — no proxy node)"
  is_running && running="${c_grn}running${c_rst}" || running="${c_red}stopped${c_rst}"
  if use_systemd; then mode="systemd user service"; else mode="self-managed supervisor (auto-restart)"; fi
  printf '%s%s%s\n' "$c_bld" "$APP status" "$c_rst"
  printf '  version : xraycli %s  /  %s %s\n' "$XRAYCLI_VERSION_SELF" "$CORE" "$(core_version)"
  printf '  core    : %s\n' "$CORE"
  printf '  listen  : %s   socks %s   http %s\n' "$LISTEN" "$SOCKS_PORT" "$HTTP_PORT"
  printf '  node    : %s\n' "$node"
  printf '  running : %b\n' "$running"
  printf '  mode    : %s\n' "$mode"
  echo
  if use_systemd; then
    systemctl --user status "$SERVICE_NAME" --no-pager -l 2>/dev/null | sed 's/^/  /' || true
  else
    printf '  unit    : none (controlled by xraycli under %s)\n' "$STATE_DIR"
    [ -f "$SUPERVISOR_PID" ] && printf '  supervisor pid : %s\n' "$(cat "$SUPERVISOR_PID")"
    [ -f "$PID_FILE" ] && printf '  xray pid       : %s\n' "$(cat "$PID_FILE")"
    have crontab && crontab -l 2>/dev/null | grep -qF "$CRON_TAG" && printf '  boot autostart : enabled (crontab @reboot)\n' || true
  fi
}

cmd_log() {
  local what="${1:-service}"
  case "$what" in
    error)  tail -n 200 -f "$STATE_DIR/error.log" ;;
    access) tail -n 200 -f "$STATE_DIR/access.log" ;;
    service)
      if use_systemd; then journalctl --user -u "$SERVICE_NAME" -e -f
      else tail -n 200 -f "$STATE_DIR/error.log"; fi ;;
    *) die "usage: xraycli log [service|error|access]" ;;
  esac
}

cmd_test() {
  ensure_installed
  load_env
  is_running || { warn "service is not running — start it first (xraycli start)"; return 1; }
  have curl || die "curl is required for 'test'"
  info "probing egress IP through http://$LISTEN:$HTTP_PORT ..."
  local ip
  ip="$(curl -fsS --max-time 15 -x "http://$LISTEN:$HTTP_PORT" https://api.ip.sb/ip 2>/dev/null \
        || curl -fsS --max-time 15 -x "http://$LISTEN:$HTTP_PORT" https://ipinfo.io/ip 2>/dev/null)"
  if [ -n "${ip:-}" ]; then ok "proxy works — egress IP: $ip"
  else die "could not reach the internet through the proxy (check the active node)"; fi
}

# --------------------------------------------------------------------------- #
#  Commands: config / ports                                                   #
# --------------------------------------------------------------------------- #
cmd_port() {
  load_env
  printf 'socks  %s:%s\n' "$LISTEN" "$SOCKS_PORT"
  printf 'http   %s:%s\n' "$LISTEN" "$HTTP_PORT"
}

cmd_config() {
  case "${1:-show}" in
    show|"") ensure_installed; [ -f "$CONFIG_FILE" ] && cat "$CONFIG_FILE" || die "no config yet" ;;
    path)    printf '%s\n' "$CONFIG_FILE" ;;
    edit)    "${EDITOR:-vi}" "$CONFIG_FILE"; cmd_regen; restart_if_running ;;
    regen)   cmd_regen; ok "regenerated $CONFIG_FILE" ;;
    *) die "usage: xraycli config [show|path|edit|regen]" ;;
  esac
}

# --------------------------------------------------------------------------- #
#  Commands: wire the HTTP proxy into Claude Code / Codex                      #
# --------------------------------------------------------------------------- #
# Both tools honour HTTP_PROXY / HTTPS_PROXY. We point them at this install's
# current HTTP inbound. `off` removes the proxy vars again, leaving other
# settings untouched.
proxy_http_url() { printf 'http://%s:%s' "$LISTEN" "$HTTP_PORT"; }

cmd_claude() {  # xraycli claude [on|off]  ->  ~/.claude/settings.json  (.env block)
  load_env; need_jq
  local action="${1:-on}"
  local dir="$HOME/.claude" file="$HOME/.claude/settings.json" tmp
  mkdir -p "$dir"
  [ -s "$file" ] || printf '{}\n' > "$file"
  jq -e . "$file" >/dev/null 2>&1 || die "$file is not valid JSON — fix or remove it, then retry"
  tmp="$(mktemp)"
  case "$action" in
    off)
      jq 'if has("env") then .env |= del(.HTTP_PROXY, .HTTPS_PROXY, .NO_PROXY) else . end
          | if (.env == {}) then del(.env) else . end' "$file" > "$tmp" && mv "$tmp" "$file" \
        && ok "Claude Code: removed proxy env from $file"
      ;;
    on|"")
      local u; u="$(proxy_http_url)"
      jq --arg u "$u" --arg np "localhost,127.0.0.1,::1" \
         '.env = ((.env // {}) + {HTTP_PROXY:$u, HTTPS_PROXY:$u, NO_PROXY:$np})' "$file" > "$tmp" \
        && mv "$tmp" "$file" \
        && ok "Claude Code -> $u   (wrote $file; restart Claude Code to apply)"
      ;;
    *) rm -f "$tmp"; die "usage: xraycli claude [on|off]" ;;
  esac
  rm -f "$tmp" 2>/dev/null || true
}

cmd_codex() {  # xraycli codex [on|off]  ->  ~/.codex/.env  (KEY=value lines)
  load_env
  local action="${1:-on}"
  local dir="$HOME/.codex" file="$HOME/.codex/.env" tmp
  mkdir -p "$dir"; touch "$file"
  tmp="$(mktemp)"
  # keep every line except the three we manage, then (re)append when turning on
  grep -vE '^[[:space:]]*(HTTP_PROXY|HTTPS_PROXY|NO_PROXY)=' "$file" > "$tmp" || true
  case "$action" in
    off)
      mv "$tmp" "$file"; ok "Codex: removed proxy env from $file"
      ;;
    on|"")
      local u; u="$(proxy_http_url)"
      { printf 'HTTP_PROXY=%s\n'  "$u"
        printf 'HTTPS_PROXY=%s\n' "$u"
        printf 'NO_PROXY=%s\n'    "localhost,127.0.0.1,::1"; } >> "$tmp"
      mv "$tmp" "$file"; ok "Codex -> $u   (wrote $file; restart Codex to apply)"
      ;;
    *) rm -f "$tmp"; die "usage: xraycli codex [on|off]" ;;
  esac
}

# --------------------------------------------------------------------------- #
#  Commands: nodes / subscription                                             #
# --------------------------------------------------------------------------- #
cmd_list() {
  need_jq; ensure_nodes
  local n; n="$(jq 'length' "$NODES_FILE")"
  if [ "$n" -eq 0 ]; then
    printf '  no nodes yet.\n'
    printf '    add one   : %sxraycli add '\''<share-link>'\''%s\n' "$c_dim" "$c_rst"
    printf '    or import : %sxraycli sub add '\''<url>'\''%s\n' "$c_dim" "$c_rst"
    return 0
  fi
  local cur; cur="$(current_name)"

  # A SUB column only earns its width once more than one subscription feeds the
  # list; until then every node has the same origin and the number says nothing.
  local subs_json='[]' show_sub=0
  if [ "$(sub_count)" -gt 1 ]; then
    show_sub=1
    subs_json="$(sub_urls | jq -R -s 'split("\n") | map(select(length > 0))')"
  fi

  # One TSV row per node: idx, active(1/0), name, proto, server:port, net/sec, sub.
  # Reads the node's descriptor; falls back to a legacy prebuilt .outbound.
  local rows
  rows="$(jq -r --arg cur "$cur" --argjson subs "$subs_json" '
    def proto:
      ( if .descriptor then .descriptor.type
        else (.outbound.protocol // "?") end )
      | if .=="shadowsocks" then "ss" elif .=="hysteria" or .=="hysteria2" then "hy2" else . end;
    def ep:
      if .descriptor then "\(.descriptor.server):\(.descriptor.port)"
      else ((.outbound.settings.vnext[0] // .outbound.settings.servers[0] // .outbound.settings) as $e
            | if ($e.address // null) != null then "\($e.address):\($e.port)" else "-" end) end;
    def ns:
      if .descriptor then
        ( if .descriptor.type=="hysteria2" then "quic/tls"
          else "\(.descriptor.network // "tcp")/\(.descriptor.security // "none")" end )
      else "\(.outbound.streamSettings.network // "tcp")/\(.outbound.streamSettings.security // "none")" end;
    def sub:
      (.source // "") as $s
      | ($subs | index($s)) | if . then (. + 1 | tostring) else "-" end;
    to_entries[]
    | [ (.key|tostring),
        (if .value.name == $cur then "1" else "0" end),
        .value.name,
        (.value|proto),
        (.value|ep),
        (.value|ns),
        (.value|sub) ] | @tsv
  ' "$NODES_FILE")"

  # size each column to its widest cell (header labels set the minimums)
  local wN=4 wP=5 wS=6 idx act name proto ep ns sub
  while IFS=$'\t' read -r idx act name proto ep ns sub; do
    [ "${#name}"  -gt "$wN" ] && wN="${#name}"
    [ "${#proto}" -gt "$wP" ] && wP="${#proto}"
    [ "${#ep}"    -gt "$wS" ] && wS="${#ep}"
  done <<< "$rows"

  local subcell=""
  [ "$show_sub" = 1 ] && subcell="$(printf '%-4s' "SUB")"
  printf '%s  %s %-2s %s%-*s  %-*s  %-*s  %s%s\n' \
    "$c_dim" " " "#" "$subcell" "$wN" "NAME" "$wP" "PROTO" "$wS" "SERVER" "NET/SEC" "$c_rst"
  local mark col
  while IFS=$'\t' read -r idx act name proto ep ns sub; do
    if [ "$act" = 1 ]; then mark="${c_grn}●${c_rst}"; col="$c_grn"; else mark=' '; col=""; fi
    subcell=""
    [ "$show_sub" = 1 ] && subcell="$(printf '%s%-4s%s' "$c_dim" "$sub" "$c_rst")"
    printf '  %s %-2s %s%s%-*s%s  %-*s  %-*s  %s%s%s\n' \
      "$mark" "$idx" "$subcell" "$col" "$wN" "$name" "$c_rst" "$wP" "$proto" "$wS" "$ep" "$c_dim" "$ns" "$c_rst"
  done <<< "$rows"
  if [ "$show_sub" = 1 ]; then
    printf '%s  ● active  ·  SUB = xraycli sub list  ·  switch: xraycli use <#|name>%s\n' "$c_dim" "$c_rst"
  else
    printf '%s  ● active  ·  switch: xraycli use <#|name>%s\n' "$c_dim" "$c_rst"
  fi
}

cmd_current() {
  local cur; cur="$(current_name)"
  [ -n "$cur" ] && echo "$cur" || echo "(direct — no proxy node)"
}

cmd_use() {
  need_jq; ensure_nodes
  local sel="${1:?usage: xraycli use <index|name>}" node name desc typ
  node="$(select_node "$sel")" || die "no such node: $sel  (see: xraycli list)"
  [ -n "$node" ] && [ "$node" != "null" ] || die "no such node: $sel"
  name="$(jq -r '.name' <<<"$node")"
  if jq -e 'has("descriptor")' <<<"$node" >/dev/null 2>&1; then
    desc="$(jq -c '.descriptor' <<<"$node")"; typ="$(jq -r '.descriptor.type' <<<"$node")"
    build_proxy_outbound "$desc" >/dev/null 2>&1 \
      || die "the '$CORE' core can't run node '$name' ($typ) — switch core: xraycli core <name>"
    printf '%s\n' "$desc" > "$ACTIVE_DESC"; rm -f "$ACTIVE_OUTBOUND"
  else
    # legacy node stored a prebuilt Xray outbound
    [ "$CORE" = xray ] || die "node '$name' predates multi-core — run 'xraycli update' to refresh it for $CORE"
    jq '.outbound | .tag="proxy"' <<<"$node" > "$ACTIVE_OUTBOUND"; rm -f "$ACTIVE_DESC"
  fi
  printf '%s\n' "$name" > "$ACTIVE_NAME_FILE"
  cmd_regen
  restart_if_running
  ok "active node: $name"
}

cmd_remove() {
  need_jq; ensure_nodes
  local sel="${1:?usage: xraycli remove <index|name>}" node name
  node="$(select_node "$sel")" || die "no such node: $sel"
  name="$(jq -r '.name' <<<"$node")"
  jq --arg n "$name" 'map(select(.name != $n))' "$NODES_FILE" > "$NODES_FILE.tmp" && mv "$NODES_FILE.tmp" "$NODES_FILE"
  if [ "$(current_name)" = "$name" ]; then cmd_direct >/dev/null; fi
  ok "removed node: $name"
}

cmd_direct() {
  rm -f "$ACTIVE_OUTBOUND" "$ACTIVE_DESC" "$ACTIVE_NAME_FILE"
  cmd_regen
  restart_if_running
  ok "switched to direct (traffic bypasses any proxy node)"
}

# --------------------------------------------------------------------------- #
#  Subscription / share-link import                                           #
#                                                                             #
#  Two subscription shapes are auto-detected by content (not by URL):         #
#    * base64 / raw : a (base64-wrapped) list of vless://, trojan://, … links #
#    * clash        : a YAML doc whose nodes live under the `proxies:` key     #
#  Each parser normalises a node into a "descriptor" JSON, and the core builder #
#  turns a descriptor into a real Xray outbound. Protocols Xray-core cannot    #
#  run (tuic, hysteria2-with-obfs, …) are recognised & skipped with a report.  #
# --------------------------------------------------------------------------- #

urldecode() { local s="${1//+/ }"; s="${s//%/\\x}"; printf '%b' "$s"; }

b64d() {  # tolerant base64 decode (arg or stdin; url-safe alphabet + missing padding)
  local s="${1:-}"; [ $# -eq 0 ] && s="$(cat)"
  s="${s//$'\n'/}"; s="${s//$'\r'/}"; s="${s//-/+}"; s="${s//_/\/}"
  local m=$(( ${#s} % 4 )); [ "$m" -ne 0 ] && s="$s$(printf '%*s' $((4-m)) '' | tr ' ' '=')"
  printf '%s' "$s" | base64 -d 2>/dev/null
}

# emit_descriptor <type> <name> <server> <port> [k=v ...]  (empty values dropped; alpn is CSV)
emit_descriptor() {
  local type="$1" name="$2" server="$3" port="$4"; shift 4
  local args=(--arg type "$type" --arg name "$name" --arg server "$server" --arg port "$port")
  local prog='{type:$type,name:$name,server:$server,port:$port}'
  local alpn_csv="" pair k v
  for pair in "$@"; do
    k="${pair%%=*}"; v="${pair#*=}"
    [ "$k" = "alpn" ] && { alpn_csv="$v"; continue; }
    [ -z "$v" ] && continue
    args+=(--arg "$k" "$v"); prog="$prog + {$k:\$$k}"
  done
  args+=(--arg alpn "$alpn_csv")
  prog="$prog + {alpn: (\$alpn | if .==\"\" then [] else split(\",\") end)}"
  jq -nc "${args[@]}" "$prog"
}

parse_vless_uri() {
  local uri="$1" rest name query userinfo hostport host port
  rest="${uri#vless://}"
  name=""; case "$rest" in *"#"*) name="$(urldecode "${rest##*#}")"; rest="${rest%%#*}";; esac
  query=""; case "$rest" in *"?"*) query="${rest#*\?}"; rest="${rest%%\?*}";; esac
  userinfo="${rest%@*}"; hostport="${rest##*@}"
  host="${hostport%:*}"; port="${hostport##*:}"
  local flow="" enc="none" sec="none" sni="" fp="" alpn="" pbk="" sid="" spx="" net="tcp" path="" hosth="" svc=""
  local IFS='&' kv k v
  for kv in $query; do
    [ -z "$kv" ] && continue
    k="${kv%%=*}"; v="$(urldecode "${kv#*=}")"
    case "$k" in
      encryption) enc="$v";; flow) flow="$v";; security) sec="$v";;
      sni|peer) sni="$v";; fp) fp="$v";; alpn) alpn="$v";;
      pbk) pbk="$v";; sid) sid="$v";; spx) spx="$v";;
      type) net="$v";; path) path="$v";; host) hosth="$v";;
      serviceName|servicename) svc="$v";;
    esac
  done
  [ -z "$sni" ] && sni="$hosth"
  emit_descriptor vless "$name" "$host" "$port" \
    uuid="$userinfo" flow="$flow" encryption="$enc" security="$sec" \
    sni="$sni" fp="$fp" alpn="$alpn" pbk="$pbk" sid="$sid" spx="$spx" \
    network="$net" wsPath="$path" wsHost="$hosth" grpcService="$svc"
}

parse_trojan_uri() {
  local uri="$1" rest name query userinfo hostport host port
  rest="${uri#trojan://}"
  name=""; case "$rest" in *"#"*) name="$(urldecode "${rest##*#}")"; rest="${rest%%#*}";; esac
  query=""; case "$rest" in *"?"*) query="${rest#*\?}"; rest="${rest%%\?*}";; esac
  userinfo="${rest%@*}"; hostport="${rest##*@}"
  host="${hostport%:*}"; port="${hostport##*:}"
  local sec="tls" sni="" fp="" alpn="" net="tcp" path="" hosth="" svc=""
  local IFS='&' kv k v
  for kv in $query; do
    [ -z "$kv" ] && continue
    k="${kv%%=*}"; v="$(urldecode "${kv#*=}")"
    case "$k" in
      security) sec="$v";; sni|peer) sni="$v";; fp) fp="$v";; alpn) alpn="$v";;
      type) net="$v";; path) path="$v";; host) hosth="$v";; serviceName|servicename) svc="$v";;
    esac
  done
  [ -z "$sni" ] && sni="$hosth"
  emit_descriptor trojan "$name" "$host" "$port" \
    password="$userinfo" security="$sec" sni="$sni" fp="$fp" alpn="$alpn" \
    network="$net" wsPath="$path" wsHost="$hosth" grpcService="$svc"
}

parse_vmess_uri() {  # vmess://<base64 of a v2rayN JSON>
  local j; j="$(b64d "${1#vmess://}")" || return 1
  [ -n "$j" ] || return 1
  jq -ce '{
    type:"vmess", name:((.ps // "")|tostring), server:(.add|tostring), port:(.port|tostring),
    uuid:(.id|tostring), alterId:((.aid // 0)|tostring), scy:((.scy // "auto")|tostring),
    network:((.net // "tcp")|tostring),
    security:(if ((.tls // "")|tostring)=="tls" then "tls" else "none" end),
    sni:((.sni // .host // "")|tostring), fp:((.fp // "")|tostring),
    wsPath:((.path // "/")|tostring), wsHost:((.host // "")|tostring),
    grpcService:((.path // "")|tostring),
    alpn:(((.alpn // "")|tostring)| if .=="" then [] else split(",") end)
  }' <<<"$j" 2>/dev/null
}

parse_ss_uri() {
  local rest="${1#ss://}" name="" method pass host port ui hp dec
  case "$rest" in *"#"*) name="$(urldecode "${rest##*#}")"; rest="${rest%%#*}";; esac
  case "$rest" in *"?"*) rest="${rest%%\?*}";; esac
  if [[ "$rest" == *"@"* ]]; then
    ui="${rest%@*}"; hp="${rest##*@}"
    ui="$(b64d "$ui" 2>/dev/null || printf '%s' "$ui")"; [ -z "$ui" ] && ui="${rest%@*}"
    method="${ui%%:*}"; pass="${ui#*:}"; host="${hp%:*}"; port="${hp##*:}"
  else
    dec="$(b64d "$rest")"; ui="${dec%@*}"; hp="${dec##*@}"
    method="${ui%%:*}"; pass="${ui#*:}"; host="${hp%:*}"; port="${hp##*:}"
  fi
  emit_descriptor shadowsocks "$name" "$host" "$port" method="$method" password="$pass" network="tcp" security="none"
}

parse_hysteria2_uri() {  # hysteria2://<auth>@host:port?params#name   (hy2:// alias)
  local uri="$1" rest name query userinfo hostport host port
  rest="${uri#*://}"
  name=""; case "$rest" in *"#"*) name="$(urldecode "${rest##*#}")"; rest="${rest%%#*}";; esac
  query=""; case "$rest" in *"?"*) query="${rest#*\?}"; rest="${rest%%\?*}";; esac
  userinfo="${rest%@*}"; hostport="${rest##*@}"
  host="${hostport%:*}"; port="${hostport##*:}"
  local sni="" obfs="" obfspw="" insecure="" alpn="" ports="" up="" down=""
  local IFS='&' kv k v
  for kv in $query; do
    [ -z "$kv" ] && continue
    k="${kv%%=*}"; v="$(urldecode "${kv#*=}")"
    case "$k" in
      sni|peer) sni="$v";; obfs) obfs="$v";; obfs-password|obfsParam) obfspw="$v";;
      insecure|allowInsecure) insecure="$v";; alpn) alpn="$v";;
      mport|ports) ports="$v";; up|upmbps) up="$v";; down|downmbps) down="$v";;
    esac
  done
  # hysteria2 URIs sometimes carry auth as user:pass — Xray uses the whole string
  emit_descriptor hysteria2 "$name" "$host" "$port" \
    password="$userinfo" sni="$sni" obfs="$obfs" obfsPassword="$obfspw" \
    insecure="$insecure" alpn="$alpn" ports="$ports" up="$up" down="$down"
}

parse_unsupported_uri() {  # keep name/host so import can report what was skipped
  local uri="$1" scheme="${1%%://*}" rest name hostport host="" port=""
  rest="${uri#*://}"
  name=""; case "$rest" in *"#"*) name="$(urldecode "${rest##*#}")"; rest="${rest%%#*}";; esac
  case "$rest" in *"?"*) rest="${rest%%\?*}";; esac
  hostport="${rest##*@}"; host="${hostport%:*}"; port="${hostport##*:}"
  emit_descriptor "$scheme" "$name" "$host" "$port"
}

parse_share_link() {  # <uri> -> descriptor JSON; nonzero on unknown scheme
  local uri="$1" scheme="${1%%://*}"
  case "$scheme" in
    vless)  parse_vless_uri "$uri" ;;
    vmess)  parse_vmess_uri "$uri" ;;
    trojan) parse_trojan_uri "$uri" ;;
    ss)     parse_ss_uri "$uri" ;;
    hysteria2|hy2) parse_hysteria2_uri "$uri" ;;
    hysteria|tuic|juicity|wireguard|wg|ssr)
            parse_unsupported_uri "$uri" ;;
    *) return 3 ;;
  esac
}

# Which protocols each core can run is decided by core_supports(); a descriptor
# type outside every builder's cases is skipped on import.

# Shared jq that turns descriptor fields into an Xray streamSettings object.
read -r -d '' STREAM_JQ <<'JQ' || true
def s: if . == null then "" else tostring end;
def stream:
  ({network: ((.network|s)|if .=="" then "tcp" else . end)})
  + ( if (.security|s) == "reality" then
        { security: "reality",
          realitySettings: {
            serverName: (.sni|s),
            fingerprint: ((.fp|s)|if .=="" then "chrome" else . end),
            publicKey: (.pbk|s),
            shortId: (.sid|s),
            spiderX: (.spx|s) } }
      elif (.security|s) == "tls" or (.security|s) == "xtls" then
        { security: "tls",
          tlsSettings: ( { serverName: (.sni|s),
                           fingerprint: ((.fp|s)|if .=="" then "chrome" else . end) }
                         + ( if ((.alpn // [])|length) > 0 then {alpn: .alpn} else {} end ) ) }
      else { security: "none" } end )
  + ( if (.network|s) == "ws" then
        { wsSettings: ( {path: ((.wsPath|s)|if .=="" then "/" else . end)}
                        + ( if (.wsHost|s) != "" then {headers:{Host:(.wsHost|s)}} else {} end ) ) }
      elif (.network|s) == "grpc" then
        { grpcSettings: {serviceName: (.grpcService|s)} }
      elif (.network|s) == "h2" or (.network|s) == "http" then
        { httpSettings: ( {path: ((.wsPath|s)|if .=="" then "/" else . end)}
                          + ( if (.wsHost|s) != "" then {host:[(.wsHost|s)]} else {} end ) ) }
      else {} end );
JQ

xray_outbound() {  # <descriptor> -> Xray outbound JSON (tag proxy)
  local d="$1" type; type="$(jq -r '.type' <<<"$d")"
  case "$type" in
    vless) jq -c "$STREAM_JQ"'
      { tag:"proxy", protocol:"vless",
        settings:{ vnext:[ { address:.server, port:(.port|tonumber),
          users:[ ( {id:.uuid, encryption:((.encryption|s)|if .=="" then "none" else . end)}
                    + ( if (.flow|s)!="" then {flow:.flow} else {} end) ) ] } ] },
        streamSettings: stream }' <<<"$d" ;;
    trojan) jq -c "$STREAM_JQ"'
      { tag:"proxy", protocol:"trojan",
        settings:{ servers:[ {address:.server, port:(.port|tonumber), password:.password} ] },
        streamSettings: stream }' <<<"$d" ;;
    vmess) jq -c "$STREAM_JQ"'
      { tag:"proxy", protocol:"vmess",
        settings:{ vnext:[ { address:.server, port:(.port|tonumber),
          users:[ {id:.uuid, alterId:((.alterId|s)|if .=="" then 0 else tonumber end), security:((.scy|s)|if .=="" then "auto" else . end)} ] } ] },
        streamSettings: stream }' <<<"$d" ;;
    shadowsocks) jq -c '
      { tag:"proxy", protocol:"shadowsocks",
        settings:{ servers:[ {address:.server, port:(.port|tonumber), method:.method, password:.password} ] },
        streamSettings:{network:((.network // "tcp")), security:"none"} }' <<<"$d" ;;
    hysteria2) jq -c '
      def s: if . == null then "" else tostring end;
      { tag:"proxy", protocol:"hysteria",
        settings:{ version:2, address:.server, port:(.port|tonumber) },
        streamSettings:{
          network:"hysteria",
          security:"tls",
          tlsSettings: ( { serverName: ((.sni|s)|if .=="" then (.server|s) else . end) }
                         + ( if ((.alpn // [])|length) > 0 then {alpn:.alpn} else {} end ) ),
          hysteriaSettings: ( { version:2, auth:(.password|s) }
                              + ( if (.up|s)   != "" then {up:(.up|s)}     else {} end )
                              + ( if (.down|s) != "" then {down:(.down|s)} else {} end )
                              + ( if (.ports|s) != "" then {udphop:{ports:(.ports|s)}} else {} end ) )
        } }' <<<"$d" ;;
    *) return 3 ;;
  esac
}

# sing-box outbound (tag "proxy") from a descriptor. sing-box uses server_port,
# a nested tls{} (with reality/utls), a transport{} for ws/grpc, and native
# hysteria2 obfs — so it runs the obfs'd nodes Xray can't.
singbox_outbound() {  # <descriptor> -> sing-box outbound JSON
  local d="$1" type; type="$(jq -r '.type' <<<"$d")"
  # shared TLS + transport builders
  local SB_JQ='
    def s: if . == null then "" else tostring end;
    def tls:
      ( { enabled:true, server_name:((.sni|s)|if .=="" then (.server|s) else . end) }
        + ( if (.security|s)=="reality" then
              { utls:{enabled:true, fingerprint:((.fp|s)|if .=="" then "chrome" else . end)},
                reality:{enabled:true, public_key:(.pbk|s), short_id:(.sid|s)} }
            else
              ( if (.fp|s)!="" then {utls:{enabled:true, fingerprint:(.fp|s)}} else {} end ) end )
        + ( if ((.insecure|s)=="true" or (.insecure|s)=="1") then {insecure:true} else {} end )
        + ( if ((.alpn // [])|length) > 0 then {alpn:.alpn} else {} end ) );
    def transport:
      if (.network|s)=="ws" then
        { transport: ( { type:"ws", path:((.wsPath|s)|if .=="" then "/" else . end) }
                       + ( if (.wsHost|s)!="" then {headers:{Host:(.wsHost|s)}} else {} end ) ) }
      elif (.network|s)=="grpc" then { transport:{ type:"grpc", service_name:(.grpcService|s) } }
      else {} end;
    def tlsopt: (if (.security|s)=="reality" or (.security|s)=="tls" or (.security|s)=="xtls" then {tls: tls} else {} end);'
  case "$type" in
    vless) jq -c "$SB_JQ"'
      { type:"vless", tag:"proxy", server:.server, server_port:(.port|tonumber), uuid:.uuid }
      + ( if (.flow|s)!="" then {flow:.flow} else {} end ) + tlsopt + transport' <<<"$d" ;;
    vmess) jq -c "$SB_JQ"'
      { type:"vmess", tag:"proxy", server:.server, server_port:(.port|tonumber), uuid:.uuid,
        security:((.scy|s)|if .=="" then "auto" else . end),
        alter_id:((.alterId|s)|if .=="" then 0 else tonumber end) } + tlsopt + transport' <<<"$d" ;;
    trojan) jq -c "$SB_JQ"'
      { type:"trojan", tag:"proxy", server:.server, server_port:(.port|tonumber), password:.password }
      + tlsopt + transport' <<<"$d" ;;
    shadowsocks) jq -c "$SB_JQ"'
      { type:"shadowsocks", tag:"proxy", server:.server, server_port:(.port|tonumber),
        method:.method, password:.password }' <<<"$d" ;;
    hysteria2) jq -c "$SB_JQ"'
      { type:"hysteria2", tag:"proxy", server:.server, server_port:(.port|tonumber), password:(.password|s) }
      + ( if (.obfs|s)!="" then {obfs:{ type:(.obfs|s), password:(.obfsPassword|s) }} else {} end )
      + ( if (.up|s)!=""   then {up_mbps:((.up|s)|gsub("[^0-9]";"")|if .=="" then 0 else tonumber end)}   else {} end )
      + ( if (.down|s)!="" then {down_mbps:((.down|s)|gsub("[^0-9]";"")|if .=="" then 0 else tonumber end)} else {} end )
      + ( if (.ports|s)!="" then {server_ports:((.ports|s)|split(",")|map(if test("-") then sub("-";":") else . + ":" + . end))} else {} end )
      + { tls: ( { enabled:true, server_name:((.sni|s)|if .=="" then (.server|s) else . end) }
                 + ( if ((.insecure|s)=="true" or (.insecure|s)=="1") then {insecure:true} else {} end )
                 + ( if ((.alpn // [])|length) > 0 then {alpn:.alpn} else {} end ) ) }' <<<"$d" ;;
    *) return 3 ;;
  esac
}

# Build the active core's proxy outbound from a descriptor. Returns non-zero
# (skip) when the active core can't run this node.
build_proxy_outbound() {  # <descriptor> -> outbound JSON (tag proxy)
  local d="$1" type obfs=0
  type="$(jq -r '.type' <<<"$d")"
  [ -n "$(jq -r '.obfs // ""' <<<"$d")" ] && obfs=1
  core_supports "$type" "$obfs" || return 3
  if [ "$CORE" = sing-box ]; then singbox_outbound "$d"; else xray_outbound "$d"; fi
}

# Flatten a Clash `proxies:` block into TAB-separated key/value records (\x1e between proxies).
read -r -d '' CLASH_AWK <<'AWK' || true
function ind(s,  n){ n=0; while(substr(s,n+1,1)==" ") n++; return n }
function trim(s){ gsub(/^[ \t]+|[ \t]+$/,"",s); return s }
function unq(s){ if(s ~ /^".*"$/ || s ~ /^'\''.*'\''$/) s=substr(s,2,length(s)-2); return s }
BEGIN{ inp=0; base=-1; sp=0; started=0; lastkey="" }
{
  line=$0; sub(/\r$/,"",line)
  if(line ~ /^[^ #-]/){
    if(line ~ /^proxies[ \t]*:/){ inp=1; next }
    else if(inp){ inp=0 }
  }
  if(!inp) next
  if(line ~ /^[ ]*$/ || line ~ /^[ ]*#/) next
  i=ind(line); c=substr(line,i+1)
  isdash = (c ~ /^- / || c=="-")
  if(isdash && (base==-1 || i==base)){
    if(started) printf "\x1e"
    started=1; base=i; sp=0; lastkey=""
    kv(substr(c,3), i+2)
    next
  }
  if(isdash && i>base){
    v=unq(trim(substr(c,3)))
    if(lastkey!="") printf "%s\t%s\n", lastkey, v
    next
  }
  kv(c, i)
}
function kv(s, indent,  pos,k,v,fk,prefix){
  pos=index(s,":"); if(pos==0) return
  k=trim(substr(s,1,pos-1)); v=trim(substr(s,pos+1))
  while(sp>0 && stkind[sp]>=indent) sp--
  prefix=(sp>0 ? stkpfx[sp] : "")
  fk=prefix k
  if(v==""){ sp++; stkind[sp]=indent; stkpfx[sp]=fk"."; lastkey=fk }
  else { printf "%s\t%s\n", fk, unq(v) }
}
AWK

clash_to_descriptors() {  # YAML on stdin -> one descriptor JSON per line
  local rec
  awk "$CLASH_AWK" | while IFS= read -r -d $'\x1e' rec || [ -n "$rec" ]; do
    [ -n "$(printf '%s' "$rec" | tr -d '[:space:]')" ] || continue
    declare -A A=(); local alpn_csv="" k v
    while IFS=$'\t' read -r k v; do
      [ -z "$k" ] && continue
      if [ "$k" = "alpn" ]; then
        v="${v//[/}"; v="${v//]/}"; v="${v//\"/}"; v="${v// /}"   # tolerate flow-style [h3, h2]
        [ -n "$v" ] && { [ -n "$alpn_csv" ] && alpn_csv="$alpn_csv,$v" || alpn_csv="$v"; }
        continue
      fi
      A["$k"]="$v"
    done <<< "$rec"
    local type="${A[type]:-}"; [ -n "$type" ] || { unset A; continue; }
    [ "$type" = "ss" ] && type="shadowsocks"
    local net="${A[network]:-tcp}" tls="${A[tls]:-}" sec="none"
    local pbk="${A[reality-opts.public-key]:-}" sid="${A[reality-opts.short-id]:-}"
    if [ -n "$pbk" ]; then sec="reality"; elif [ "$tls" = "true" ]; then sec="tls"; fi
    local sni="${A[servername]:-${A[sni]:-}}"
    emit_descriptor "$type" "${A[name]:-}" "${A[server]:-}" "${A[port]:-}" \
      uuid="${A[uuid]:-}" password="${A[password]:-${A[auth]:-}}" flow="${A[flow]:-}" \
      network="$net" security="$sec" sni="$sni" fp="${A[client-fingerprint]:-}" \
      pbk="$pbk" sid="$sid" spx="${A[reality-opts.spider-x]:-}" alpn="$alpn_csv" \
      wsPath="${A[ws-opts.path]:-}" wsHost="${A[ws-opts.headers.Host]:-}" \
      grpcService="${A[grpc-opts.grpc-service-name]:-}" \
      alterId="${A[alterId]:-}" scy="${A[cipher]:-}" method="${A[cipher]:-}" \
      obfs="${A[obfs]:-}" obfsPassword="${A[obfs-password]:-}" \
      insecure="${A[skip-cert-verify]:-}" ports="${A[ports]:-}" \
      up="${A[up]:-}" down="${A[down]:-}"
    unset A
  done
}

# Extract the subscription URL of each provider under a Clash `proxy-providers:`
# block. Emits one URL per line. Crucially, it returns a provider's *own* `url:`
# (a direct child of the provider map) and NOT the `url:` nested under its
# `health-check:` — the indentation/stack depth tells the two apart.
read -r -d '' CLASH_PROVIDER_AWK <<'AWK' || true
function ind(s,  n){ n=0; while(substr(s,n+1,1)==" ") n++; return n }
function trim(s){ gsub(/^[ \t]+|[ \t]+$/,"",s); return s }
function unq(s){ if(s ~ /^".*"$/ || s ~ /^'\''.*'\''$/) s=substr(s,2,length(s)-2); return s }
BEGIN{ inpp=0; ppind=0; sp=0 }
{
  line=$0; sub(/\r$/,"",line)
  if(line ~ /^[ \t]*#/ || line ~ /^[ \t]*$/) next
  i=ind(line); c=substr(line,i+1)
  if(!inpp){
    if(c ~ /^proxy-providers[ \t]*:/){ inpp=1; ppind=i; sp=0 }
    next
  }
  if(i<=ppind){                                  # dedented out of the block
    inpp=0
    if(c ~ /^proxy-providers[ \t]*:/){ inpp=1; ppind=i; sp=0 }
    next
  }
  pos=index(c,":"); if(pos==0) next
  k=trim(substr(c,1,pos-1)); v=trim(substr(c,pos+1))
  while(sp>0 && stkind[sp]>=i) sp--             # pop to current depth
  if(v==""){ sp++; stkind[sp]=i; next }         # a nested map key
  if(k=="url" && sp==1) print unq(v)            # provider_name > url  (depth 1)
}
AWK

clash_provider_urls() { awk "$CLASH_PROVIDER_AWK"; }  # Clash YAML on stdin -> urls

sublist_to_descriptors() {  # decoded/raw link list on stdin -> descriptors
  local line d
  while IFS= read -r line || [ -n "$line" ]; do
    line="$(printf '%s' "$line" | tr -d '\r')"
    line="${line#"${line%%[![:space:]]*}"}"
    [ -z "$line" ] && continue
    case "$line" in *"://"*) ;; *) continue;; esac
    if d="$(parse_share_link "$line")" && [ -n "$d" ]; then printf '%s\n' "$d"; fi
  done
}

fetch_url() {  # <url|path> -> stdout
  local u="$1"
  case "$u" in
    http://*|https://*|file://*)
      if have curl; then curl -fsSL --max-time 30 "$u"
      else wget -qO- "$u"; fi ;;
    *) [ -f "$u" ] && cat "$u" || return 1 ;;
  esac
}

detect_format() {  # <file> -> clash | base64 | raw | unknown
  local f="$1" dec
  if grep -qiE '^[[:space:]]*proxies[[:space:]]*:' "$f" \
     || grep -qiE '^[[:space:]]*proxy-providers[[:space:]]*:' "$f" \
     || grep -qi 'proxy-groups' "$f"; then
    echo clash; return
  fi
  dec="$(tr -d '[:space:]' < "$f" | b64d)"
  if printf '%s' "$dec" | grep -q '://'; then echo base64; return; fi
  if grep -q '://' "$f"; then echo raw; return; fi
  echo unknown
}

# Turn a fetched subscription FILE into descriptor JSON lines. For Clash docs
# this parses any inline `proxies:` AND expands every `proxy-providers:` entry —
# fetching each provider's url (which itself carries the real `proxies:`) and
# parsing that too. <depth> guards against a provider that points back at itself.
descriptors_from_content() {  # <file> [depth] -> descriptors on stdout
  local f="$1" depth="${2:-0}" fmt descs urls u ptmp pd
  fmt="$(detect_format "$f")"
  case "$fmt" in
    base64) tr -d '[:space:]' < "$f" | b64d | sublist_to_descriptors; return ;;
    raw)    sublist_to_descriptors < "$f"; return ;;
    unknown) return 1 ;;
    clash) : ;;
  esac

  descs="$(clash_to_descriptors < "$f")"           # inline proxies (may be empty)

  urls="$(clash_provider_urls < "$f")"
  if [ -n "$urls" ]; then
    while IFS= read -r u; do
      [ -n "$u" ] || continue
      if [ "$depth" -ge 2 ]; then
        warn "proxy-provider nesting too deep — skipping: $u"; continue
      fi
      info "expanding proxy-provider: $u" >&2
      ptmp="$(mktemp)"
      if fetch_url "$u" > "$ptmp" 2>/dev/null && [ -s "$ptmp" ]; then
        pd="$(descriptors_from_content "$ptmp" $((depth+1)))"
        [ -n "$pd" ] && descs="${descs:+$descs$'\n'}$pd"
      else
        warn "proxy-provider fetch failed or empty: $u"
      fi
      rm -f "$ptmp"
    done <<< "$urls"
  fi
  printf '%s' "$descs"
}

unique_name() {  # <base> <nodes-json> -> a name not present in nodes
  local base="$1" arr="$2" n="$1" i=1
  # An empty arr would make `jq -e` exit 0 (the filter never runs), and this
  # loop would spin forever chasing a collision that isn't there.
  [ -n "$arr" ] || arr='[]'
  while jq -e --arg n "$n" 'any(.[]?; .name==$n)' <<<"$arr" >/dev/null 2>&1; do
    i=$((i+1)); n="$base #$i"
  done
  printf '%s' "$n"
}

reselect_active() {  # keep the active node if it still exists, else pick the first
  ensure_nodes
  local count cur first
  count="$(jq 'length' "$NODES_FILE")"
  if [ "$count" -eq 0 ]; then cmd_direct >/dev/null; warn "no usable nodes — switched to direct"; return; fi
  cur="$(current_name)"
  if [ -n "$cur" ] && jq -e --arg n "$cur" 'any(.[]; .name==$n)' "$NODES_FILE" >/dev/null 2>&1; then
    cmd_use "$cur" >/dev/null; ok "active node kept: $cur"
  else
    first="$(jq -r '.[0].name' "$NODES_FILE")"
    cmd_use "$first" >/dev/null; ok "active node set to: $first"
  fi
}

# Fetch one source and print its descriptors, one JSON object per line.
# Progress noise goes to stderr — stdout is data. Returns non-zero (without
# killing the run) so a bad URL can't sink an update of the others.
fetch_descriptors() {  # <url|file>
  local src="$1" tmp fmt descs
  tmp="$(mktemp)"
  if ! fetch_url "$src" > "$tmp" 2>/dev/null || [ ! -s "$tmp" ]; then
    rm -f "$tmp"; warn "fetch failed or empty response: $src"; return 1
  fi
  fmt="$(detect_format "$tmp")"
  if [ "$fmt" = unknown ]; then
    rm -f "$tmp"; warn "unrecognised format (want Clash YAML or base64/raw links): $src"; return 1
  fi
  info "$src [$fmt]" >&2
  descs="$(descriptors_from_content "$tmp" 0)"    # inline proxies + proxy-providers
  rm -f "$tmp"
  [ -n "$descs" ] || { warn "no nodes found in: $src"; return 1; }
  printf '%s' "$descs"
}

# Merge one source's descriptors into a nodes array. Callers run this in a
# command substitution, so tallies can't ride back on globals — the whole result
# comes out as one JSON envelope: {nodes, added, skipped, skips}.
merge_descriptors() {  # <nodes-json> <source-tag> <descriptors>
  local nodes="$1" srctag="$2" descs="$3" d nm typ added=0 skipped=0 skips=""
  while IFS= read -r d; do
    [ -n "$d" ] || continue
    nm="$(jq -r '.name // "node"' <<<"$d")"; typ="$(jq -r '.type' <<<"$d")"
    [ -n "$nm" ] || nm="$typ"
    if build_proxy_outbound "$d" >/dev/null 2>&1; then
      nm="$(unique_name "$nm" "$nodes")"
      nodes="$(jq -c --arg n "$nm" --arg s "$srctag" --argjson d "$d" \
        '. + [{name:$n, source:$s, descriptor:$d}]' <<<"$nodes")"
      added=$((added+1))
    else
      skipped=$((skipped+1)); skips="$skips
    - $nm ($typ) — $(skip_reason "$d")"
    fi
  done <<< "$descs"
  jq -cn --argjson nodes "$nodes" --argjson added "$added" \
         --argjson skipped "$skipped" --arg skips "$skips" \
    '{nodes:$nodes, added:$added, skipped:$skipped, skips:$skips}'
}

# Fetch every source, merge onto <base-nodes>, save, and show the result.
# Sources that fail are warned about and skipped; returns non-zero (leaving
# NODES_FILE untouched) only when not a single one came through.
import_write() {  # <base-nodes-json> <src>...
  need_jq; ensure_nodes
  local nodes="$1"; shift
  [ -n "$nodes" ] || nodes='[]'
  local src descs res got=0 srcs=0 added=0 skipped=0 skips=""
  for src in "$@"; do
    srcs=$((srcs+1))
    descs="$(fetch_descriptors "$src")" || continue
    res="$(merge_descriptors "$nodes" "$src" "$descs")"
    nodes="$(jq -c '.nodes' <<<"$res")"
    added=$((added + $(jq -r '.added' <<<"$res")))
    skipped=$((skipped + $(jq -r '.skipped' <<<"$res")))
    skips="$skips$(jq -r '.skips' <<<"$res")"
    got=$((got+1))
  done
  [ "$got" -gt 0 ] || return 1

  printf '%s\n' "$nodes" > "$NODES_FILE"
  local total; total="$(jq 'length' "$NODES_FILE")"
  if [ "$srcs" -gt 1 ]; then
    ok "imported $added node(s) from $got/$srcs subscription(s) — $total in list [core=$CORE]"
  else
    ok "imported $added node(s) — $total in list [core=$CORE]"
  fi
  [ "$skipped" -gt 0 ] && warn "skipped $skipped node(s) the '$CORE' core can't run:$skips"
  reselect_active
  cmd_list
}

# Why the active core skips a descriptor — a helpful, fix-oriented one-liner.
skip_reason() {  # <descriptor>
  local d="$1" typ; typ="$(jq -r '.type' <<<"$d")"
  if [ "$typ" = hysteria2 ] && [ -n "$(jq -r '.obfs // ""' <<<"$d")" ] && [ "$CORE" = xray ]; then
    printf 'hysteria2 with obfs — Xray has no Salamander; run: xraycli core sing-box'
  else
    printf "the '%s' core has no '%s' outbound" "$CORE" "$typ"
  fi
}

cmd_add() {
  local link="${1:-}"
  [ -n "$link" ] || die "usage: xraycli add '<share-link>'   (vless:// vmess:// trojan:// ss://)"
  need_jq
  local d typ nm
  d="$(parse_share_link "$link")" || die "unrecognised link scheme: ${link%%://*}"
  [ -n "$d" ] || die "could not parse the link"
  typ="$(jq -r '.type' <<<"$d")"; nm="$(jq -r '.name // "node"' <<<"$d")"; [ -n "$nm" ] || nm="$typ"
  build_proxy_outbound "$d" >/dev/null 2>&1 || die "the '$CORE' core can't run '$typ' — $(skip_reason "$d")"
  ensure_nodes
  local nodes; nodes="$(jq -c --arg n "$nm" 'map(select(.name != $n))' "$NODES_FILE")"
  nm="$(unique_name "$nm" "$nodes")"
  jq -c --arg n "$nm" --argjson d "$d" \
    '. + [{name:$n, source:"manual", descriptor:$d}]' <<<"$nodes" > "$NODES_FILE"
  ok "added node: $nm ($typ)"
  echo "  activate it with:  xraycli use '$nm'"
}

# SUB_FILE holds one subscription URL per line, blank lines ignored. The old
# single-URL layout is just a one-line file, so existing installs need no
# migration.
sub_urls()   { [ -f "$SUB_FILE" ] || return 0; grep -v '^[[:space:]]*$' "$SUB_FILE" 2>/dev/null || true; }
sub_count()  { sub_urls | grep -c '' || true; }
sub_has()    { local u; while IFS= read -r u; do [ "$u" = "$1" ] && return 0; done < <(sub_urls); return 1; }
sub_forget() { { sub_urls | grep -vxF "$1" || true; } > "$SUB_FILE.tmp" && mv "$SUB_FILE.tmp" "$SUB_FILE"; }

# Nodes an update must preserve: the hand-added ones. Nodes carrying a URL come
# back from that URL, and pre-0.2 nodes have no source at all — both are rebuilt
# or dropped, which is what `update` has always done.
manual_nodes() { ensure_nodes; jq -c 'map(select((.source // "") == "manual"))' "$NODES_FILE"; }

cmd_import() {  # xraycli import [--append] <url|file>   (one-off; URL not saved)
  local append=0
  if [ "${1:-}" = --append ]; then append=1; shift; fi
  local src="${1:?usage: xraycli import [--append] <url|file>}"
  need_jq; ensure_nodes
  local base
  if [ "$append" = 1 ]; then base="$(cat "$NODES_FILE")"; else base="$(manual_nodes)"; fi
  import_write "$base" "$src" || die "import failed — node list unchanged"
  [ "$append" = 1 ] || printf '%s    one-off import · keep it across updates with: xraycli sub add <url>%s\n' \
    "$c_dim" "$c_rst"
  return 0
}

sub_list() {
  local n; n="$(sub_count)"
  if [ "$n" -eq 0 ]; then
    printf '  no subscriptions yet.\n'
    printf '    add one : %sxraycli sub add '\''<url>'\''%s\n' "$c_dim" "$c_rst"
    return 0
  fi
  need_jq; ensure_nodes
  printf '%s  %-2s %-5s %s%s\n' "$c_dim" "#" "NODES" "URL" "$c_rst"
  local i=1 u c
  while IFS= read -r u; do
    c="$(jq --arg s "$u" '[.[] | select((.source // "") == $s)] | length' "$NODES_FILE")"
    printf '  %-2s %-5s %s\n' "$i" "$c" "$u"
    i=$((i+1))
  done < <(sub_urls)
  printf '%s  refresh all: xraycli update%s\n' "$c_dim" "$c_rst"
}

sub_add() {
  local url="${1:?usage: xraycli sub add <url>}"
  need_jq; ensure_nodes
  sub_has "$url" && die "already subscribed: $url"
  # Save first so the node list can already resolve this URL to a SUB number,
  # then take it back out if the URL turns out to yield nothing.
  printf '%s\n' "$url" >> "$SUB_FILE"
  import_write "$(cat "$NODES_FILE")" "$url" || { sub_forget "$url"; die "subscription not added"; }
  ok "subscription saved — $(sub_count) in total"
}

sub_rm() {
  local sel="${1:?usage: xraycli sub rm <#|url>}" url
  [ "$(sub_count)" -gt 0 ] || die "no subscriptions"
  if [[ "$sel" =~ ^[0-9]+$ ]]; then
    url="$(sub_urls | sed -n "${sel}p")"
    [ -n "$url" ] || die "no subscription #$sel — see: xraycli sub list"
  else
    url="$sel"; sub_has "$url" || die "not subscribed: $url"
  fi
  need_jq; ensure_nodes
  sub_forget "$url"
  local before after
  before="$(jq 'length' "$NODES_FILE")"
  jq --arg s "$url" 'map(select((.source // "") != $s))' "$NODES_FILE" > "$NODES_FILE.tmp" \
    && mv "$NODES_FILE.tmp" "$NODES_FILE"
  after="$(jq 'length' "$NODES_FILE")"
  ok "removed subscription: $url  ($((before-after)) node(s) dropped)"
  reselect_active
  cmd_list
}

cmd_sub() {
  case "${1:-list}" in
    add)        sub_add "${2:-}" ;;
    rm|remove)  sub_rm "${2:-}" ;;
    list|show)  sub_list ;;
    set)        # "this is my only subscription" — replace the lot
      local url="${2:?usage: xraycli sub set <url>}"
      import_write "$(manual_nodes)" "$url" || die "subscription not set — node list unchanged"
      printf '%s\n' "$url" > "$SUB_FILE"
      ok "subscription set (replaced any others)" ;;
    clear)      rm -f "$SUB_FILE"; ok "all subscriptions forgotten (nodes kept — drop them with: xraycli rm <name>)" ;;
    update)     cmd_update ;;
    *) die "usage: xraycli sub {add <url>|rm <#|url>|list|set <url>|clear|update}" ;;
  esac
}

cmd_update() {
  need_jq; ensure_nodes
  local n; n="$(sub_count)"
  [ "$n" -gt 0 ] || die "no subscription set — run: xraycli sub add '<url>'"
  info "updating from $n subscription(s)"
  local urls=() u
  while IFS= read -r u; do urls+=("$u"); done < <(sub_urls)
  # Rebuild every subscription's nodes; hand-added ones ride through untouched.
  import_write "$(manual_nodes)" "${urls[@]}" || die "update failed — node list unchanged"
}

# --------------------------------------------------------------------------- #
#  Commands: version / uninstall / help                                       #
# --------------------------------------------------------------------------- #
cmd_version() {
  load_env
  printf 'xraycli %s\n' "$XRAYCLI_VERSION_SELF"
  printf '%-7s %s\n' "$CORE" "$(core_version)"
}

# xraycli core [show | xray | sing-box]  — show or switch the proxy core.
cmd_core() {
  load_env
  local sub="${1:-show}"
  case "$sub" in
    show|"") printf 'core: %s' "$CORE"
             [ -x "$CORE_BIN" ] && printf ' (%s, %s)\n' "$(core_version)" "$CORE_BIN" || printf ' (binary missing: %s)\n' "$CORE_BIN" ;;
    xray|sing-box|singbox)
      local want="$sub"; [ "$want" = singbox ] && want="sing-box"
      [ "$want" = "$CORE" ] && { ok "already using $want"; return 0; }
      [ -x "$CORE_DIR/$want" ] || die "$want is not installed at $CORE_DIR/$want — install it: re-run install.sh --core $want"
      # persist XRAYCLI_CORE in the env file (idempotent)
      mkdir -p "$CONFIG_DIR"
      if grep -q '^XRAYCLI_CORE=' "$ENV_FILE" 2>/dev/null; then
        sed -i "s|^XRAYCLI_CORE=.*|XRAYCLI_CORE=\"$want\"|" "$ENV_FILE"
      else
        printf 'XRAYCLI_CORE="%s"\n' "$want" >> "$ENV_FILE"
      fi
      load_env                       # re-resolve CORE/CORE_BIN
      cmd_regen                      # rebuild config for the new core
      restart_if_running
      ok "switched core to $CORE ($(core_version))"
      echo "  re-run 'xraycli update' to re-evaluate nodes the previous core had skipped."
      ;;
    *) die "usage: xraycli core [show|xray|sing-box]" ;;
  esac
}

remove_bashrc_block() {
  local begin="# >>> xraycli >>>" end="# <<< xraycli <<<"
  [ -f "$BASHRC" ] || return 0
  grep -qF "$begin" "$BASHRC" || return 0
  awk -v b="$begin" -v e="$end" '
    $0==b {skip=1} !skip {print} $0==e {skip=0}
  ' "$BASHRC" > "$BASHRC.xraycli.tmp" && mv "$BASHRC.xraycli.tmp" "$BASHRC"
  ok "removed xraycli block from ~/.bashrc"
}

cmd_uninstall() {
  local yes=0 keep=0 dolinger=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -y|--yes)        yes=1 ;;
      --keep-config)   keep=1 ;;
      --disable-linger) dolinger=1 ;;
      *) die "unknown uninstall option: $1" ;;
    esac
    shift
  done

  echo "This will remove xraycli and all of its data from your account:"
  echo "  - stop & remove the user service ($SERVICE_NAME)"
  echo "  - delete $DATA_DIR"
  echo "  - delete $STATE_DIR"
  [ "$keep" -eq 1 ] && echo "  - KEEP  $CONFIG_DIR (per --keep-config)" \
                     || echo "  - delete $CONFIG_DIR"
  echo "  - remove the xraycli block from ~/.bashrc"
  echo "  - remove $BIN_SELF"
  echo
  if [ "$yes" -ne 1 ]; then
    printf 'Proceed? [y/N] '
    read -r ans
    case "$ans" in y|Y|yes|YES) ;; *) echo "aborted."; return 0 ;; esac
  fi

  # 1) stop everything (self-managed supervisor + any systemd service)
  sm_stop 2>/dev/null || true
  cron_disable 2>/dev/null || true
  if have_systemd_user; then
    systemctl --user disable --now "$SERVICE_NAME" 2>/dev/null || true
  fi
  rm -f "$PID_FILE" "$SUPERVISOR_PID"

  # 2) remove the systemd unit from every place it may have been written
  #    (the manager's resolved dir AND this $HOME's XDG dir, from older versions).
  local u removed=0
  for u in "$SERVICE_FILE" "$XDG_CONFIG_HOME/systemd/user/$SERVICE_NAME"; do
    [ -e "$u" ] && { rm -f "$u"; removed=1; }
  done
  if [ "$removed" -eq 1 ]; then
    if have_systemd_user; then
      systemctl --user daemon-reload 2>/dev/null || true
      systemctl --user reset-failed "$SERVICE_NAME" 2>/dev/null || true
    fi
    ok "removed systemd unit(s)"
  fi

  # 3) data + state (+ config unless kept)
  rm -rf "$DATA_DIR" && ok "removed $DATA_DIR"
  rm -rf "$STATE_DIR" && ok "removed $STATE_DIR"
  if [ "$keep" -eq 1 ]; then
    warn "kept $CONFIG_DIR"
  else
    rm -rf "$CONFIG_DIR" && ok "removed $CONFIG_DIR"
  fi

  # 4) bashrc block
  remove_bashrc_block

  # 5) optionally disable linger (user-global; off by default)
  if [ "$dolinger" -eq 1 ] && have loginctl; then
    loginctl disable-linger "$(id -un)" 2>/dev/null && ok "disabled linger" || true
  fi

  # 6) remove self last (safe: inode stays alive until this process exits)
  rm -f "$BIN_SELF" && ok "removed $BIN_SELF"

  echo
  ok "xraycli uninstalled. Open a new shell (or 'source ~/.bashrc') to drop the removed helpers."
}

cmd_help() {
  cat <<EOF
${c_bld}xraycli${c_rst} — user-scope Xray proxy manager (v$XRAYCLI_VERSION_SELF)

${c_bld}Lifecycle${c_rst}
  start                 start the proxy
  stop                  stop the proxy
  restart               restart the proxy
  status                show status, ports, active node
  enable                start now + auto-start on boot (systemd, or crontab @reboot)
  disable               stop + remove boot auto-start
  log [service|error|access]   follow logs
  test                  verify the proxy reaches the internet (prints egress IP)

${c_bld}Nodes / subscription${c_rst}  ${c_dim}(auto-detects base64 & Clash; skips protocols Xray can't run)${c_rst}
  add '<share-link>'    add one node (vless:// vmess:// trojan:// ss://)
  sub add '<url>'       subscribe to a URL and import its nodes (repeatable)
  sub list              list subscriptions with their node counts
  sub rm <#|url>        unsubscribe and drop the nodes that came from it
  sub set '<url>'       make this the only subscription (replaces any others)
  sub clear             forget every subscription URL (keeps the nodes)
  update                re-fetch every subscription and rebuild the node list
  import [--append] <url|file>   one-off import from a URL or local file
  list                  list saved nodes ('●' = active)
  use <index|name>      select the active node
  remove <index|name>   delete a node
  current               print the active node
  direct                use no proxy node (pass-through)

${c_bld}Config${c_rst}
  port                  print the local proxy ports
  core [show|xray|sing-box]   show / switch the proxy core (sing-box adds hy2+obfs)
  config [show|path|edit|regen]   view / edit / rebuild config.json
  version               print xraycli + core versions

${c_bld}App integration${c_rst}  ${c_dim}(point AI CLIs at this proxy's HTTP inbound)${c_rst}
  claude [on|off]       write/remove HTTP proxy in ~/.claude/settings.json
  codex  [on|off]       write/remove HTTP proxy in ~/.codex/.env

${c_bld}Maintenance${c_rst}
  uninstall [-y] [--keep-config] [--disable-linger]   remove everything cleanly
  help                  this message

Proxy ports (point your apps/shell at these): ${c_dim}xraycli port${c_rst}
EOF
}

# --------------------------------------------------------------------------- #
#  Dispatch                                                                    #
# --------------------------------------------------------------------------- #
main() {
  load_env               # resolve CORE / CORE_BIN before any command runs
  init_systemd_paths
  init_service_mode
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    __supervise)      cmd_supervise ;;
    start)            cmd_start "$@" ;;
    stop)             cmd_stop "$@" ;;
    restart)          cmd_restart "$@" ;;
    status|st)        cmd_status "$@" ;;
    enable)           cmd_enable "$@" ;;
    disable)          cmd_disable "$@" ;;
    log|logs)         cmd_log "$@" ;;
    test)             cmd_test "$@" ;;
    add)              cmd_add "$@" ;;
    sub|subscribe)    cmd_sub "$@" ;;
    update)           cmd_update "$@" ;;
    import)           cmd_import "$@" ;;
    list|ls)          cmd_list "$@" ;;
    use|select)       cmd_use "$@" ;;
    remove|rm|del)    cmd_remove "$@" ;;
    current)          cmd_current "$@" ;;
    direct)           cmd_direct "$@" ;;
    port|ports)       cmd_port "$@" ;;
    core)             cmd_core "$@" ;;
    config|conf)      cmd_config "$@" ;;
    claude|claude-code) cmd_claude "$@" ;;
    codex)            cmd_codex "$@" ;;
    service)          case "${1:-}" in
                        install)
                          if use_systemd; then write_service_unit; ok "installed service unit -> $SERVICE_FILE"
                          else ok "self-managed mode: no systemd unit (all under $HOME); use 'xraycli enable' for boot autostart"; fi ;;
                        *) die "usage: xraycli service install" ;;
                      esac ;;
    regen|_regen)     cmd_regen "$@"; ok "regenerated config" ;;
    version|-v|--version) cmd_version "$@" ;;
    uninstall|remove-all) cmd_uninstall "$@" ;;
    help|-h|--help|"") cmd_help ;;
    *) die "unknown command: $cmd  (try: xraycli help)" ;;
  esac
}
main "$@"
